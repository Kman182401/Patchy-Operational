{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git remote:*)",
      "Bash(.venv/bin/python -m pytest:*)",
      "Bash(.venv/bin/python -m ruff:*)",
      "Bash(.venv/bin/python -m mypy:*)",
      "Bash(systemctl status:*)",
      "Bash(systemctl is-active:*)",
      "Bash(systemctl cat:*)",
      "Bash(journalctl:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "respectGitignore": true,
  "alwaysThinkingEnabled": true,
  "hooks": {
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if find /home/karson/Patchy_Bot/telegram-qbt/patchy_bot /home/karson/Patchy_Bot/telegram-qbt/tests -name '*.py' -mmin -2 2>/dev/null | grep -q .; then cd /home/karson/Patchy_Bot/telegram-qbt && .venv/bin/python -m pytest tests/ -q --tb=short 2>&1 | tail -20; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/karson/Patchy_Bot/.claude/hooks/memory-recorder.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/karson/Patchy_Bot/.claude/hooks/session-finalizer.sh"
          }
        ]
      }
    ]
  }
}
