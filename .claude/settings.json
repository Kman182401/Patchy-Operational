{
  "respectGitignore": true,
  "permissions": {
    "allow": [
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git remote:*)",
      "Bash(.venv/bin/python -m pytest:*)",
      "Bash(.venv/bin/python -m ruff:*)",
      "Bash(.venv/bin/python -m mypy:*)",
      "Bash(systemctl status:*)",
      "Bash(systemctl is-active:*)",
      "Bash(systemctl cat:*)",
      "Bash(journalctl:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(/home/karson/Patchy_Bot/.env)",
      "Read(/home/karson/Patchy_Bot/**/.env)",
      "Read(/home/karson/Patchy_Bot/**/.env.*)",
      "Read(./secrets/**)",
      "Read(/home/karson/Patchy_Bot/secrets/**)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/karson/Patchy_Bot/.claude/hooks/pre-bash-guard.sh"
          }
        ]
      },
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}}' || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/karson/Patchy_Bot/.claude/hooks/post-edit-format.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/karson/Patchy_Bot/.claude/hooks/stop-audit-trigger.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/karson/Patchy_Bot/.claude/hooks/auto-approve.sh",
            "statusMessage": "Auto-approving..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": false,
    "semgrep@claude-plugins-official": false,
    "context7@claude-plugins-official": true,
    "playwright@claude-plugins-official": false,
    "chrome-devtools-mcp@claude-plugins-official": false
  },
  "alwaysThinkingEnabled": true
}