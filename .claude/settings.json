{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git remote:*)",
      "Bash(.venv/bin/python -m pytest:*)",
      "Bash(.venv/bin/python -m ruff:*)",
      "Bash(.venv/bin/python -m mypy:*)",
      "Bash(systemctl status:*)",
      "Bash(systemctl is-active:*)",
      "Bash(systemctl cat:*)",
      "Bash(journalctl:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "respectGitignore": true,
  "alwaysThinkingEnabled": false,
  "model": "sonnet",
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "semgrep@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "playwright@claude-plugins-official": false,
    "chrome-devtools-mcp@claude-plugins-official": false
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/karson/Patchy_Bot/.claude/hooks/pre-bash-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/karson/Patchy_Bot/.claude/hooks/post-edit-format.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/karson/Patchy_Bot/.claude/hooks/memory-recorder.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/karson/Patchy_Bot/.claude/hooks/session-finalizer.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/karson/Patchy_Bot/.claude/hooks/auto-approve.sh",
            "statusMessage": "Auto-approving..."
          }
        ]
      }
    ]
  }
}
