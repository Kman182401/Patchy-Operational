# === Local backups (never commit) ===
.context-trim-backup-*/

# === Python ===
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
*.egg

# === Environment & Secrets ===
# Tokens, API keys, and local config that must never be committed
.env
.env.*

# === Database / State ===
state.sqlite3*
*.sqlite3
*.sqlite3-journal

# === Claude Code local config ===
# May contain session tokens or local-only settings
.claude/settings.local.json
.remember/

# === IDE / Editor ===
.idea/
.vscode/
*.swp
*.swo
*~

# === OS artifacts ===
.DS_Store
Thumbs.db

# === Testing / Cache ===
.pytest_cache/
.coverage
htmlcov/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dev-debug.log
# Dependency directories
node_modules/
# Environment variables
# Editor directories and files
.idea
.vscode
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
# OS specific

# Task files
# tasks.json
# tasks/

# === Obsidian vault (Patchy Ops) ===
# Device-specific workspace state (changes constantly, causes noise)
Patchy Ops/.obsidian/workspace.json
Patchy Ops/.obsidian/workspace-mobile.json

# Sync conflict artifacts
Patchy Ops/.obsidian/.obsidian-sync-*
Patchy Ops/.obsidian/sync-conflicts/
Patchy Ops/.trash/

# Plugin runtime data (device-specific, can be large)
Patchy Ops/.obsidian/plugins/*/data.json

# Cache
Patchy Ops/.obsidian/cache

# KEEP TRACKED (useful for vault reproducibility):
# - app.json, appearance.json, core-plugins.json, core-plugins-migration.json
# - hotkeys.json, templates.json, daily-notes.json, bookmarks.json
# - community-plugins.json

# Stale duplicate vault — leave untracked
Patchy/
